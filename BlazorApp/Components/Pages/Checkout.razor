@page "/checkout"
@rendermode InteractiveServer

<PageTitle>Checkout</PageTitle>

@using BlazorApp.Model
@using BlazorApp.Services
@using System.Globalization
@inject OrderState OrderState
@inject NavigationManager NavigationManager
@inject PedidoService PedidoSvc
@implements IDisposable

<div class="main ">
	<EditForm  EditContext="editContext" OnValidSubmit="SalvarPedido" OnInvalidSubmit="ShowError">
		<DataAnnotationsValidator />
		
		<div class="checkout-cols">

			<OrderReview pedido="OrderState.PedidoAtivo" />
			<div>
				<AddressEditor endereco="OrderState.PedidoAtivo.EnderecoEntrega" />
				@if (isError)
				{

					<ValidationSummary />
				}
			</div>
			

		</div>

		<input class="checkout-button btn btn-warning" 
		type="submit"  
		value="Confirmar Pedido"
		disabled="@(isError || isSubmitting)" />
			
		
	</EditForm>
</div>
@code {
	bool isSubmitting;

	private Pedido pedido => OrderState.PedidoAtivo;

	private EditContext editContext;

	bool isError = false;

	private async Task CheckSubmission(EditContext editContext)
	{
		try
		{
			isSubmitting = true;
			var model = pedido.EnderecoEntrega;

			isError = string.IsNullOrWhiteSpace(model?.NomeCliente) 
			|| string.IsNullOrWhiteSpace(model?.Cidade)
			|| string.IsNullOrWhiteSpace(model?.Bairro)
			|| string.IsNullOrWhiteSpace(model?.Rua)
			|| string.IsNullOrWhiteSpace(model?.Numero)
			|| string.IsNullOrWhiteSpace(model?.Telefone);

			if (!isError)
			{
				await SalvarPedido();
			}

		}
		catch (Exception ex)
		{
			Console.WriteLine($"Erro ao salvar endereço: {ex.Message}");
		}
	}

	private async Task SalvarPedido()
	{
		try
		{
			int newOrderId = await PedidoSvc.PlaceOrderAsync(NavigationManager.BaseUri, pedido);
			OrderState.ResetOrder();
			NavigationManager.NavigateTo($"/myorder/{newOrderId}");
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Erro ao salvar pedido: {ex.Message}");
		}
		finally
		{
			isSubmitting = false;
		}
	}

	public void Dispose()
	{
		OrderState.OnChange -= StateHasChanged;
	}
	protected void ShowError()
	{
		isError = true;
	}

	protected override void OnInitialized()
	{

		if (pedido.EnderecoEntrega == null)
		{
			pedido.EnderecoEntrega = new Endereco();
		}
		editContext = new(OrderState.PedidoAtivo.EnderecoEntrega);

		editContext.OnFieldChanged += HandleFieldChanged;

		OrderState.OnChange += StateHasChanged;
		
	}

	private void HandleFieldChanged(object sender, FieldChangedEventArgs e)
	{
		isError = !editContext.Validate();
		StateHasChanged();
	}

}
